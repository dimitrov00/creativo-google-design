{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "dist/apps/functions",
    "predeploy": ["pnpm nx build functions"]
  },
  "hosting": [
    {
      "target": "client",
      "public": "dist/apps/client/browser",
      "ignore": ["firebase.json", "**/.*"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "staff",
      "public": "dist/apps/staff/browser",
      "ignore": ["firebase.json", "**/.*"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "marketing",
      "public": "dist/apps/marketing/browser",
      "ignore": ["firebase.json", "**/.*"],
      "rewrites": [
        {
          "source": "**",
          "run": {
            "serviceId": "marketing-ssr",
            "region": "us-central1"
          }
        }
      ]
    }
  ],
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": false
    }
  }
}
