{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "declaration": true,
    "types": ["node"],
    "composite": true,
    "rootDir": "../../.."
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/**/*.type-spec.ts"
  ],
  "references": [
    {
      "path": "../shared/tsconfig.lib.json"
    },
    {
      "path": "../../domain/accounts/tsconfig.lib.json"
    },
    {
      "path": "../../domain/kernel/tsconfig.lib.json"
    },
    {
      "path": "../../domain/engagement/tsconfig.lib.json"
    }
  ]
}
