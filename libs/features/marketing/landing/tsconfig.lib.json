{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": [],
    "composite": true,
    "rootDir": "../../../..",
    "sourceMap": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/test-setup.ts"
  ],
  "references": [
    {
      "path": "../../../shared/ui/tsconfig.lib.json"
    },
    {
      "path": "../../../shared/cursor/tsconfig.lib.json"
    },
    {
      "path": "../../../infrastructure/i18n/tsconfig.lib.json"
    }
  ]
}
