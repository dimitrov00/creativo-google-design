{
  "//": "Template — replace 'creativo-replace-me' with the real Firebase project ID once it exists, then run `firebase use --add` yourself; no Firebase CLI auth actions are taken on your behalf. The hosting site ID (web, below) must also be created first via `firebase hosting:sites:create <site-id>` and mapped with `firebase target:apply hosting web <site-id>`.",
  "projects": {
    "default": "creativo-replace-me"
  },
  "targets": {
    "creativo-replace-me": {
      "hosting": {
        "web": ["creativo-web"]
      }
    }
  }
}
