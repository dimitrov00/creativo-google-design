{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "nx",
        "serve",
        "web",
        "--host",
        "0.0.0.0",
        "--allowedHosts"
      ],
      "port": 4200,
      "autoPort": true
    },
    {
      "name": "web-prod",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "nx",
        "serve",
        "web",
        "--configuration",
        "production",
        "--port",
        "4310",
        "--host",
        "0.0.0.0",
        "--allowedHosts"
      ],
      "port": 4310,
      "autoPort": true
    },
    {
      "name": "web-static",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "http.server",
        "4477",
        "-d",
        "dist/apps/web/browser"
      ],
      "port": 4477,
      "autoPort": true
    }
  ]
}
